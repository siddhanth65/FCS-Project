# Application Configuration
APP_NAME=Secure Job Search Platform
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql://jobplatform:your_secure_password@localhost/secure_job_platform

# Security
SECRET_KEY=your-secret-key-minimum-32-characters-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Configuration
OTP_SECRET_KEY=your-otp-secret-key-change-this-in-production
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

# Email Configuration (for OTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@securejobplatform.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Encryption (generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-base64-encoded-encryption-key

# CORS
CORS_ORIGINS=["https://localhost", "https://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# HTTPS/SSL
SSL_CERT_PATH=../ssl/cert.pem
SSL_KEY_PATH=../ssl/key.pem
USE_SSL=True

# Frontend
FRONTEND_URL=https://localhost

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
